# Connection details for the King County housing database.
# Copy this file to .env and fill in the real values. Never commit .env.

DATABASE=<your-database-name>
USER_DB=<your-username>
PASSWORD=<your-password>
HOST=<your-host>
PORT=5432

# Full SQLAlchemy connection string (used by 03_fetching_the_data_eda.ipynb)
DB_STRING=postgresql://<your-username>:<your-password>@<your-host>:5432/<your-database-name>
